# Neon Postgres — https://console.neon.tech (eu-central-1 Frankfurt)
DATABASE_URL=

# Auth
AUTH_SECRET=      # openssl rand -base64 32
AUTH_URL=http://localhost:3000

# Seed accounts
SEED_OWNER_EMAIL=
SEED_OWNER_PASSWORD=
SEED_DP_EMAIL=
SEED_DP_PASSWORD=

# Vercel Blob — vercel.com/storage/blob
BLOB_READ_WRITE_TOKEN=

# API-Football — https://dashboard.api-football.com
APIFOOTBALL_KEY=

# Research — cascade: Perplexity → Tavily → native Claude search
# Perplexity: https://perplexity.ai/settings/api ($50 min topup) — not available at launch
PERPLEXITY_API_KEY=
PERPLEXITY_MODEL=sonar

# Tavily — free 1000/month — https://tavily.com
TAVILY_API_KEY=

# Telegram — @BotFather for token, @userinfobot for chat IDs
TELEGRAM_BOT_TOKEN=
TELEGRAM_ADMIN_CHAT_ID=

# Resend — https://resend.com/api-keys
RESEND_API_KEY=
RESEND_FROM=noreply@pocoloco.app

# Engine model
CLAUDE_MODEL=claude-sonnet-4-6

# GitHub — for manual triggers from dashboard
GITHUB_DISPATCH_TOKEN=
GITHUB_REPO=buddy1974/pocoloco

# Feature flags
STRATEGY_VALUE_1X2_ENABLED=true
STRATEGY_VALUE_OU25_ENABLED=false
STRATEGY_ARB_ENABLED=false
DEMO_MODE_ENABLED=true
